# Development Environment Configuration for Inventory Service
ENVIRONMENT=development
SERVICE_NAME=inventory-service
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_TO_FILE=false
LOG_TO_CONSOLE=true
LOG_FILE_PATH=inventory-service.log

# Port configuration
PORT=3000

# Database configuration
DATABASE_URL=postgres://user:password@localhost:5432/inventory_db?sslmode=disable

# Redis configuration
REDIS_URL=redis://localhost:6379

# CORS configuration
CORS_ORIGIN=http://localhost:3000
