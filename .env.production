# Production Environment Configuration for Inventory Service
ENVIRONMENT=production
SERVICE_NAME=inventory-service
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_FILE_PATH=/var/log/inventory-service.log

# Port configuration
PORT=3000

# Database configuration
DATABASE_URL=${DATABASE_URL}

# Redis configuration
REDIS_URL=${REDIS_URL}

# CORS configuration
CORS_ORIGIN=${CORS_ORIGIN}
